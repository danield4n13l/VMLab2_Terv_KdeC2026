@book{VegyipariKeszulekekSzerkesztesi1986,
  title = {Vegyipari készülékek: szerkesztési atlasz},
  shorttitle = {Vegyipari készülékek},
  editor = {{Dr. Pálfi Zoltán}},
  date = {1986},
  eprint = {tQnUsgEACAAJ},
  eprinttype = {googlebooks},
  publisher = {Műszaki Kiadó},
  location = {Budapest},
  abstract = {A népgazdaság egyik rohamosan fejlődő iparága a vegyipar. A korszerű vegyipart egyre nagyobb egységkapacitású üzemek, egyre szélsőségesebb nyomás- és hőmérséklet-értékekkel és korrozív anyagokkal dolgozó technológiák jellemzik. Az ilyen üzemek gépészeti tervezése igen komoly, a korábbiaktól eltérő feladatot jelent. E problémák megoldása során felhalmozódott ismeretanyagból létrejött a gépészmérnöki tudomány új ága, a vegyipari gépészet. Az új tudományág kialakította a maga sajátos szakirodalmát. Hazánkban is számos ilyen témájú munka jelent meg, de a hazai vegyipari gépészet szakirodalma mind ez ideig nélkülözte a legfontosabb alapvető ismereteket tartalmazó, átfogó művet. A szerzők munkájukkal ezt a hiányt igyekeztek pótolni. Megkísérelték a vegyipari gépészmérnökök mindennapi munkájához nélkülözhetetlen ismeretanyagot röviden és áttekinthetően összefoglalni. Tekintettel arra, hogy a feldolgozott szakterület igen szétágazó és kiterjedt, ez komoly feladatot jelentett. A szerzők több évtizedes tervezői és egyetemi oktatói tapasztalatukra támaszkodva, legjobb tudásuk szerint igyekeztek megoldani ezt a feladatot, ennek ellenére munkájuk bizonyára még nem teljes, és nem mentes az útkereséssel járó hiányosságoktól és hibáktól.},
  isbn = {978-963-10-6249-X},
  langid = {hungarian},
  pagetotal = {616}
}
