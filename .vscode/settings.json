{
    "cSpell.language": "en,hu",
    "editor.wordWrap": "bounded",
    "latex-workshop.latex.outDir": "%DIR%/out/",
    "latex-workshop.hover.preview.newcommand.newcommandFile": "include/headers/defs.tex",
    "latex-workshop.intellisense.citation.backend": "biblatex",
    "latex-workshop.latex.build.rootfileInStatus": true,
    "latex-workshop.latex.clean.subfolder.enabled": true,
    "latex-workshop.latex.tools": [
        {
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-xelatex",
                "-outdir=%OUTDIR%",
                "%DOC%"
            ],
            "command": "latexmk",
            "env": {},
            "name": "xelatexmk"
        },
        {
            "args": [
                "%DOCFILE%",
                "--input-directory=%OUTDIR%"
            ],
            "command": "biber",
            "env": {},
            "name": "biber"
        },
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk (xelatex)",
            "tools": [
                "xelatexmk"
            ]
        },
        {
            "name": "xelatex+biber",
            "tools": [
                "xelatexmk",
                "biber",
                "xelatexmk"
            ]
        },
        {
            "name": "latexmk",
            "tools": [
                "latexmk"
            ]
        },
        {
            "name": "Compile Rnw files",
            "tools": [
                "rnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "Compile Jnw files",
            "tools": [
                "jnw2tex",
                "latexmk"
            ]
        },
        {
            "name": "Compile Pnw files",
            "tools": [
                "pnw2tex",
                "latexmk"
            ]
        }
    ],
    "editor.tabSize": 4,
    "markdown.validate.enabled": false,
    "latex-workshop.linting.chktex.convertOutput.column.chktexrcTabSize": 4,
    "latex-workshop.intellisense.subsuperscript.enabled": true,
    "latex-workshop.latex.texDirs": [
        "include/headers/"
    ],
    "latex-workshop.latex.clean.args": [
        "-outdir=%OUTDIR%",
        "-emulate-aux-dir",
        "-auxdir=%OUTDIR%/aux/",
        "-c",
        "-cd",
        "%TEX%",
    ],
    "latex-workshop.hover.preview.mathjax.extensions": [
        "cases",
        "mhchem"
    ],
    "latex-workshop.view.pdf.color.dark.backgroundColor": "",
    "latex-workshop.view.pdf.color.dark.pageBorderColor": "",
    "latex-workshop.view.pdf.color.dark.pageColorsBackground": "",
    "latex-workshop.view.pdf.color.dark.pageColorsForeground": "",
}